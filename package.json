{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",

  "scripts": {
    "frontend": "vite --port 3000",
    "backend": "cd backend && python -m uvicorn app.main:app --port 8000",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "build": "vite build",
    "start": "npm run dev"
  },

  "dependencies": {
    "axios": "^1.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },

  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.14",
    "autoprefixer": "^10.4.21"
  }
}